{
  "name": "eleven-monokai",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "make_theme": "node src/index.ts",
    "make_vsce": "vsce package",
    "build": "run-s compile make_theme make_vsce",
    "format": "prettier --write ./**/*.{json,ts,mjs}"
  },
  "repository": {
    "url": "https://github.com/alekseyt/vscode-two-monokai"
  },
  "engines": {
    "vscode": "^1.33.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "%darkThemeLabel%",
        "uiTheme": "vs-dark",
        "path": "./themes/Two Monokai Dark.json"
      },
      {
        "label": "%lightThemeLabel%",
        "uiTheme": "vs",
        "path": "./themes/Two Monokai Light.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@vscode/vsce": "^3.7.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
