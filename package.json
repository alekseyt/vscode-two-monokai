{
  "name": "eleven-monokai",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "make_theme": "node src/index.ts",
    "make_vsce": "vsce package",
    "build": "run-s compile make_theme make_vsce",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write './**/*.{json,ts,mjs}'"
  },
  "repository": {
    "url": "https://github.com/alekseyt/vscode-two-monokai"
  },
  "engines": {
    "vscode": "^1.33.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "%darkThemeLabel%",
        "uiTheme": "vs-dark",
        "path": "./themes/eleven-monokai-dark.json"
      },
      {
        "label": "%lightThemeLabel%",
        "uiTheme": "vs",
        "path": "./themes/eleven-monokai-light.json"
      }
    ]
  },
  "files": [
    "themes/**/*.json",
    "package.json",
    "package.nls*.json",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "latest",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
