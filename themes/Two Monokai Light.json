{
  "name": "Eleven Monokai",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.lineHighlightBackground": "#4444440a",
    "editorLineNumber.foreground": "#9e9e9e",
    "editorLineNumber.activeForeground": "#0a70ff",
    "activityBar.background": "#d8d8d8",
    "activityBar.border": "#d8d8d8",
    "activityBar.activeBorder": "#d8d8d8",
    "activityBar.foreground": "#1f1f1f",
    "activityBar.inactiveForeground": "#616161",
    "statusBar.background": "#d8d8d8",
    "statusBar.debuggingBackground": "#d8d8d8",
    "statusBar.noFolderBackground": "#d8d8d8",
    "statusBar.foreground": "#1f1f1f",
    "statusBarItem.remoteBackground": "#d8d8d8",
    "statusBarItem.remoteForeground": "#1f1f1f",
    "titleBar.activeBackground": "#d8d8d8",
    "editor.foreground": "#1c1514",
    "editor.background": "#ffffff",
    "editorBracketMatch.border": "#616161"
  },
  "tokenColors": [
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal",
        "variable",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "constant.other.color",
        "storage.modifier",
        "storage.type.modifier",
        "storage.type.struct",
        "storage.type.class",
        "storage.type.enum",
        "storage.type.namespace",
        "storage.type.template",
        "storage.type.function.arrow.ts",
        "storage.type.property.ts",
        "storage.type.interface.ts",
        "storage.type.type.ts",
        "storage.type.function.ts"
      ],
      "settings": {
        "foreground": "#e14775"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name",
        "entity.other.inherited-class",
        "storage.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#0e9ee8"
      }
    },
    {
      "name": "Member access",
      "scope": [
        "variable.other.property",
        "variable.object.property",
        "variable.other.member",
        "variable.other.object.property",
        "string.other.link",
        "variable.other.lua",
        "support.variable.glsl"
      ],
      "settings": {
        "foreground": "#0a70ff"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9e9e9e"
      }
    },
    {
      "name": "Functions, Methods",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "keyword.other.special-method",
        "entity.name.scope-resolution",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#269d69"
      }
    },
    {
      "name": "Number, Constant, Embedded",
      "scope": [
        "constant.numeric",
        "support.constant",
        "constant.language",
        "constant.character",
        "constant.escape",
        "keyword.other.unit",
        "support.contant.glsl",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#af00db"
      }
    },
    {
      "name": "String, Symbols, Markup Heading",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "#cc7a0a"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#e14775"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "#e14775"
      }
    },
    {
      "name": "Language methods",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#e14775"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0e9ee8"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#af00db"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#0e9ee8"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": {
        "foreground": "#0e9ee8"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "foreground": "#0a70ff",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup Quote, Lists",
      "scope": [
        "punctuation.definition.list",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#269d69"
      }
    },
    {
      "name": "Markup Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Strikethrough",
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Markup Headings",
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#269d69"
      }
    },
    {
      "name": "Markup Heading Text",
      "scope": [
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#cc7a0a"
      }
    },
    {
      "name": "Markup Inline",
      "scope": [
        "markup.inline.raw",
        "markup.raw",
        "markup.fenced_code.block",
        "markup.table"
      ],
      "settings": {
        "foreground": "#af00db"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": [
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#0a70ff"
      }
    }
  ]
}
